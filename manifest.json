{
  "manifest_version": 3,
  "name": "Vedro",
  "version": "2.1",
  "description": "A minimalistic, frosted-glass new tab. Clear sky, clear mind.",
  "homepage_url": "https://github.com/stralej/start-page",
  "permissions": ["geolocation"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://ipapi.co/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "icons": {
    "16":  "images/icon-16.png",
    "32":  "images/icon-32.png",
    "48":  "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "strahinja@learn-serbian.rs",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}